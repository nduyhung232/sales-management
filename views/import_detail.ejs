<% const active = 'imports' %>
<%- include('partials/header') %>

<a href="/imports" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Back</a>
<a href="/imports/edit/<%= order.import_id %>" class="btn btn-sm btn-outline-warning mb-3 ms-2"><i class="bi bi-pencil"></i> <%= t('edit') %></a>
<h4><%= t('import') %>: <%= order.import_code %></h4>
<p><strong><%= t('supplier') %>:</strong> <%= order.supplier_name || '-' %> | <strong><%= t('import_date') %>:</strong> <%= order.import_date %> | <strong><%= t('total') %>:</strong> <%= Number(order.total_amount).toLocaleString() %>đ</p>
<% if (order.note) { %><p><strong><%= t('note') %>:</strong> <%= order.note %></p><% } %>

<table class="table">
  <thead><tr><th><%= t('product_code') %></th><th><%= t('product_name') %></th><th><%= t('quantity') %></th><th><%= t('unit_price') %></th><th><%= t('amount') %></th></tr></thead>
  <tbody>
    <% lines.forEach(l => { %>
    <tr>
      <td><%= l.product_code %></td>
      <td><%= l.product_name %></td>
      <td><%= l.quantity %></td>
      <td class="text-end"><%= Number(l.unit_price).toLocaleString() %>đ</td>
      <td class="text-end"><%= Number(l.line_amount).toLocaleString() %>đ</td>
    </tr>
    <% }) %>
  </tbody>
</table>

<%- include('partials/footer') %>
