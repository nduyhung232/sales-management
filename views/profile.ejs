<% const active = '' %>
<%- include('partials/header') %>

<h4 class="mb-3"><i class="bi bi-person"></i> Edit Profile</h4>

<form method="POST" action="/profile" style="max-width:500px">
  <div class="mb-3">
    <label class="form-label"><%= t('username') %></label>
    <input type="text" class="form-control" value="<%= profile.username %>" disabled>
  </div>
  <div class="mb-3">
    <label class="form-label"><%= t('full_name') %></label>
    <input type="text" name="full_name" class="form-control" value="<%= profile.full_name || '' %>">
  </div>
  <div class="mb-3">
    <label class="form-label">Phone</label>
    <input type="text" name="phone" class="form-control" value="<%= profile.phone || '' %>">
  </div>
  <div class="mb-3">
    <label class="form-label">Email</label>
    <input type="email" name="email" class="form-control" value="<%= profile.email || '' %>">
  </div>
  <button type="submit" class="btn btn-primary"><i class="bi bi-check"></i> <%= t('save') %></button>
</form>

<%- include('partials/footer') %>
