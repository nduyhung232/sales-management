<% const active = '' %>
<%- include('partials/header') %>

<h4 class="mb-3"><i class="bi bi-key"></i> <%= t('change_password') %></h4>

<% if (error) { %><div class="alert alert-danger" style="max-width:400px"><%= error %></div><% } %>
<% if (success) { %><div class="alert alert-success" style="max-width:400px"><%= success %></div><% } %>

<form method="POST" action="/profile/password" style="max-width:400px">
  <div class="mb-3">
    <label class="form-label"><%= t('current_password') %></label>
    <input type="password" name="current_password" class="form-control" required>
  </div>
  <div class="mb-3">
    <label class="form-label"><%= t('new_password') %></label>
    <input type="password" name="new_password" class="form-control" required minlength="4">
  </div>
  <div class="mb-3">
    <label class="form-label"><%= t('confirm_password') %></label>
    <input type="password" name="confirm_password" class="form-control" required minlength="4">
  </div>
  <button type="submit" class="btn btn-primary"><i class="bi bi-check"></i> <%= t('save') %></button>
  <a href="/profile" class="btn btn-outline-secondary ms-2"><%= t('cancel') %></a>
</form>

<%- include('partials/footer') %>
