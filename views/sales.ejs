<% const active = 'sales' %>
<%- include('partials/header') %>

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
  <h4 class="mb-0"><i class="bi bi-cart"></i> <%= t('sales') %></h4>
  <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addModal"><i class="bi bi-plus"></i> <%= t('create_sale') %></button>
</div>

<div class="table-responsive">
<table class="table table-hover">
  <thead><tr><th><%= t('code') %></th><th><%= t('customer_name') %></th><th><%= t('sale_date') %></th><th><%= t('total') %></th><th><%= t('discount') %></th><th><%= t('final_amount') %></th><th><%= t('payment_method') %></th><th></th></tr></thead>
  <tbody>
    <% orders.forEach(o => { %>
    <tr>
      <td><%= o.sale_code %></td>
      <td><%= o.customer_name || 'Walk-in' %></td>
      <td><%= o.sale_date %></td>
      <td class="text-end"><%= Number(o.total_amount).toLocaleString() %></td>
      <td class="text-end"><%= Number(o.discount).toLocaleString() %></td>
      <td class="text-end fw-bold text-success"><%= Number(o.final_amount).toLocaleString() %>đ</td>
      <td><%= o.payment_method %></td>
      <td><a href="/sales/detail/<%= o.sale_id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
    </tr>
    <% }) %>
    <% if (!orders.length) { %><tr><td colspan="8" class="text-center text-muted"><%= t('no_sales') %></td></tr><% } %>
  </tbody>
</table>
</div>

<div class="modal fade" id="addModal"><div class="modal-dialog modal-lg"><div class="modal-content">
  <form method="POST" action="/sales/create">
    <div class="modal-header"><h5><%= t('create_sale') %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <div class="row mb-3">
        <div class="col"><input type="text" name="customer_name" class="form-control" placeholder="<%= t('customer_name') %>"></div>
        <div class="col"><input type="text" name="customer_phone" class="form-control" placeholder="<%= t('customer_phone') %>"></div>
      </div>
      <div class="row mb-3">
        <div class="col-4"><input type="number" name="discount" class="form-control" placeholder="<%= t('discount') %>" step="1000"></div>
        <div class="col-4">
          <select name="payment_method" class="form-select">
            <option value="CASH"><%= t('cash') %></option>
            <option value="TRANSFER"><%= t('transfer') %></option>
          </select>
        </div>
        <div class="col-4"><input type="text" name="note" class="form-control" placeholder="<%= t('note') %>"></div>
      </div>
      <h6>Items</h6>
      <div id="saleLines">
        <div class="row mb-2 line-row gx-2">
          <div class="col">
            <select name="product_ids" class="form-select form-select-sm product-select ts-select" required>
              <option value="">-- <%= t('products') %> --</option>
              <% products.forEach(p => { %><option value="<%= p.product_id %>" data-price="<%= p.sell_price %>"><%= p.product_name %></option><% }) %>
            </select>
          </div>
          <div class="col-2"><input type="number" name="quantities" class="form-control form-control-sm" placeholder="<%= t('quantity') %>" step="1" required></div>
          <div class="col-3"><input type="number" name="unit_prices" class="form-control form-control-sm price-input" placeholder="<%= t('price') %>" step="0.01" required></div>
          <div class="col-auto"><button type="button" class="btn btn-sm btn-outline-danger" onclick="this.closest('.line-row').remove()"><i class="bi bi-x"></i></button></div>
        </div>
      </div>
      <button type="button" class="btn btn-sm btn-outline-secondary mt-2" onclick="addSaleLine()"><i class="bi bi-plus"></i> <%= t('add_line') %></button>
    </div>
    <div class="modal-footer"><button type="submit" class="btn btn-success"><%= t('save') %></button></div>
  </form>
</div></div></div>

<script>
const saleLineTemplate = `
  <div class="row mb-2 line-row gx-2">
    <div class="col">
      <select name="product_ids" class="form-select form-select-sm product-select ts-select-new" required>
        <option value="">-- <%= t('products') %> --</option>
        <% products.forEach(p => { %><option value="<%= p.product_id %>" data-price="<%= p.sell_price %>"><%= p.product_name %></option><% }) %>
      </select>
    </div>
    <div class="col-2"><input type="number" name="quantities" class="form-control form-control-sm" placeholder="<%= t('quantity') %>" step="1" required></div>
    <div class="col-3"><input type="number" name="unit_prices" class="form-control form-control-sm price-input" placeholder="<%= t('price') %>" step="0.01" required></div>
    <div class="col-auto"><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeLine(this)"><i class="bi bi-x"></i></button></div>
  </div>`;

function addSaleLine() {
  document.getElementById('saleLines').insertAdjacentHTML('beforeend', saleLineTemplate);
  // Init TomSelect on new selects
  document.querySelectorAll('.ts-select-new').forEach(el => {
    el.classList.remove('ts-select-new');
    new TomSelect(el, { create: false, sortField: { field: 'text', direction: 'asc' } });
  });
  bindPrice();
}
function removeLine(btn) {
  btn.closest('.line-row').remove();
}
function bindPrice() {
  document.querySelectorAll('.product-select').forEach(sel => {
    sel.onchange = function() {
      const price = this.selectedOptions[0]?.dataset.price || '';
      this.closest('.line-row').querySelector('.price-input').value = price;
    };
  });
}
bindPrice();
</script>

<%- include('partials/footer') %>
