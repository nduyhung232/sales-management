<% const active = 'reports' %>
<%- include('partials/header') %>

<h4 class="mb-3"><i class="bi bi-bar-chart"></i> <%= t('reports') %></h4>

<form class="row mb-4" style="max-width:500px">
  <div class="col"><input type="date" name="from" class="form-control" value="<%= fromDate %>"></div>
  <div class="col"><input type="date" name="to" class="form-control" value="<%= toDate %>"></div>
  <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-search"></i> <%= t('filter') %></button></div>
</form>

<div class="row mb-4">
  <div class="col-md-3">
    <div class="stat-card" style="background:#27ae60">
      <div class="small"><%= t('net_revenue') %></div>
      <div class="fs-5 fw-bold"><%= Number(sales.net_revenue).toLocaleString() %>đ</div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="stat-card" style="background:#e67e22">
      <div class="small"><%= t('total_revenue') %></div>
      <div class="fs-5 fw-bold"><%= Number(sales.total_revenue).toLocaleString() %>đ</div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="stat-card" style="background:#2980b9">
      <div class="small"><%= t('total_discount') %></div>
      <div class="fs-5 fw-bold"><%= Number(sales.total_discount).toLocaleString() %>đ</div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="stat-card" style="background:#8e44ad">
      <div class="small"><%= t('total_orders') %></div>
      <div class="fs-5 fw-bold"><%= sales.total_orders %></div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header fw-bold"><%= t('top_products') %></div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <thead><tr><th><%= t('products') %></th><th><%= t('quantity') %></th><th><%= t('amount') %></th></tr></thead>
          <tbody>
            <% topProducts.forEach(p => { %>
            <tr><td><%= p.product_name %></td><td><%= p.total_qty %></td><td class="text-end"><%= Number(p.total_amount).toLocaleString() %>đ</td></tr>
            <% }) %>
            <% if (!topProducts.length) { %><tr><td colspan="3" class="text-center text-muted">No data</td></tr><% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card">
      <div class="card-header fw-bold"><%= t('daily_revenue') %></div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <thead><tr><th><%= t('sale_date') %></th><th><%= t('net_revenue') %></th></tr></thead>
          <tbody>
            <% dailyRevenue.forEach(d => { %>
            <tr><td><%= d.date %></td><td class="text-end"><%= Number(d.revenue).toLocaleString() %>đ</td></tr>
            <% }) %>
            <% if (!dailyRevenue.length) { %><tr><td colspan="2" class="text-center text-muted">No data</td></tr><% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
