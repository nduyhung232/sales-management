<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sales Management</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    .sidebar {
      min-height: 100vh; background: #2c3e50; position: fixed;
      width: 220px; z-index: 1000; transition: transform 0.3s ease;
    }
    .sidebar a.nav-link { color: #ecf0f1; text-decoration: none; padding: 12px 20px; display: block; }
    .sidebar a.nav-link:hover, .sidebar a.nav-link.active { background: #34495e; color: #fff; }
    .main-content { margin-left: 220px; padding: 24px; min-height: 100vh; transition: margin-left 0.3s ease; }
    .stat-card { border-radius: 10px; padding: 20px; color: #fff; margin-bottom: 12px; }
    .top-bar { background: #fff; border-bottom: 1px solid #eee; padding: 10px 24px; display: flex; align-items: center; justify-content: flex-end; margin: -24px -24px 24px -24px; }
    .mobile-header { display: none; background: #2c3e50; color: #fff; padding: 12px 16px; position: sticky; top: 0; z-index: 999; }
    .sidebar-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 999; }

    /* Tablet */
    @media (max-width: 991px) {
      .sidebar { width: 200px; }
      .main-content { margin-left: 200px; padding: 16px; }
      .top-bar { margin: -16px -16px 16px -16px; }
    }

    /* Mobile */
    @media (max-width: 767px) {
      .sidebar { transform: translateX(-100%); width: 260px; }
      .sidebar.open { transform: translateX(0); }
      .sidebar-overlay.open { display: block; }
      .main-content { margin-left: 0; padding: 12px; }
      .mobile-header { display: flex; align-items: center; justify-content: space-between; }
      .top-bar { display: none; }
      .table-responsive { font-size: 0.85rem; }
      .card { margin-bottom: 12px; }
      .btn { padding: 0.4rem 0.75rem; font-size: 0.85rem; }
      h2, h3, h4 { font-size: 1.2rem; }
    }
  </style>
  <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">
</head>
<body>
  <!-- Mobile header with hamburger -->
  <div class="mobile-header">
    <button class="btn btn-outline-light btn-sm" onclick="toggleSidebar()">
      <i class="bi bi-list fs-5"></i>
    </button>
    <span class="fw-bold"><i class="bi bi-shop"></i> <%= t('app_name') %></span>
    <div class="dropdown">
      <button class="btn btn-sm btn-outline-light dropdown-toggle" data-bs-toggle="dropdown">
        <i class="bi bi-person-circle"></i>
      </button>
      <ul class="dropdown-menu dropdown-menu-end">
        <li><a class="dropdown-item" href="/profile"><i class="bi bi-pencil"></i> <%= t('edit_profile') %></a></li>
        <li><a class="dropdown-item" href="/profile/password"><i class="bi bi-key"></i> <%= t('change_password') %></a></li>
        <li><hr class="dropdown-divider"></li>
        <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right"></i> <%= t('logout') %></a></li>
      </ul>
    </div>
  </div>

  <!-- Overlay for mobile -->
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

  <div class="sidebar d-flex flex-column" id="sidebar">
    <div class="p-3 text-white fw-bold fs-5"><i class="bi bi-shop"></i> <%= t('app_name') %></div>
    <a href="/sales" class="nav-link <%= typeof active !== 'undefined' && active === 'sales' ? 'active' : '' %>"><i class="bi bi-cart"></i> <%= t('sales') %></a>
    <a href="/categories" class="nav-link <%= typeof active !== 'undefined' && active === 'categories' ? 'active' : '' %>"><i class="bi bi-tags"></i> <%= t('categories') %></a>
    <a href="/products" class="nav-link <%= typeof active !== 'undefined' && active === 'products' ? 'active' : '' %>"><i class="bi bi-box"></i> <%= t('products') %></a>
    <a href="/imports" class="nav-link <%= typeof active !== 'undefined' && active === 'imports' ? 'active' : '' %>"><i class="bi bi-download"></i> <%= t('import') %></a>
    <a href="/reports" class="nav-link <%= typeof active !== 'undefined' && active === 'reports' ? 'active' : '' %>"><i class="bi bi-bar-chart"></i> <%= t('reports') %></a>
    <div class="p-3 text-white-50 small">
      <a href="?lang=vi" class="text-decoration-none <%= lang === 'vi' ? 'text-white fw-bold' : 'text-white-50' %>">VI</a>
      <span class="text-white-50 mx-1">|</span>
      <a href="?lang=en" class="text-decoration-none <%= lang === 'en' ? 'text-white fw-bold' : 'text-white-50' %>">EN</a>
    </div>
  </div>
  <div class="main-content">
    <!-- Top bar with user dropdown -->
    <div class="top-bar">
      <div class="dropdown">
        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
          <i class="bi bi-person-circle"></i> <%= user ? (user.full_name || user.username) : '' %>
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li><a class="dropdown-item" href="/profile"><i class="bi bi-pencil"></i> <%= t('edit_profile') %></a></li>
          <li><a class="dropdown-item" href="/profile/password"><i class="bi bi-key"></i> <%= t('change_password') %></a></li>
          <li><hr class="dropdown-divider"></li>
          <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right"></i> <%= t('logout') %></a></li>
        </ul>
      </div>
    </div>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('open');
    }
  </script>
