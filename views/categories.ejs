<% const active = 'categories' %>
<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4><i class="bi bi-tags"></i> <%= t('categories') %></h4>
  <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addModal"><i class="bi bi-plus"></i> <%= t('add_category') %></button>
</div>

<table class="table table-hover">
  <thead><tr><th><%= t('name') %></th><th><%= t('description') %></th><th></th></tr></thead>
  <tbody>
    <% categories.forEach(c => { %>
    <tr>
      <td><%= c.category_name %></td>
      <td><%= c.description || '-' %></td>
      <td>
        <form method="POST" action="/categories/delete/<%= c.category_id %>" style="display:inline" onsubmit="return confirm('Delete?')">
          <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
        </form>
      </td>
    </tr>
    <% }) %>
    <% if (!categories.length) { %><tr><td colspan="3" class="text-center text-muted"><%= t('no_categories') %></td></tr><% } %>
  </tbody>
</table>

<div class="modal fade" id="addModal"><div class="modal-dialog"><div class="modal-content">
  <form method="POST" action="/categories/add">
    <div class="modal-header"><h5><%= t('add_category') %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <div class="mb-3"><input type="text" name="category_name" class="form-control" placeholder="<%= t('category_name') %>" required></div>
      <div class="mb-3"><textarea name="description" class="form-control" placeholder="<%= t('description') %>" rows="2"></textarea></div>
    </div>
    <div class="modal-footer"><button type="submit" class="btn btn-primary"><%= t('save') %></button></div>
  </form>
</div></div></div>

<%- include('partials/footer') %>
